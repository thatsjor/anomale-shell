{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0e1c2190",
                "editor.background": "#0e1c2190",
                "editor.foreground": "#c2c6c7",
                "text": "#c2c6c7",
                "text.muted": "#c2c6c770",
                "text.ignored": "#c2c6c740",
                "text.placeholder": "#c2c6c750",
                "ignored": "#c2c6c730",
                "element.hover": "#c2c6c730",
                "ghost_element.hover": "#879fa830",
                "ghost_element.selected": "#879fa830",
                "ghost_element.active": "#879fa860",
                "border": "#0e1c21",
                "editor.highlighted_line.background": "#879fa810",
                "editor.active_line.background": "#879fa810",
                "panel.background": "#0e1c2190",
                "title_bar.background": "#0e1c2190",
                "title_bar.inactive_background": "#0e1c2190",
                "status_bar.background": "#0e1c2190",
                "drop_target.background": "#0e1c2190",
                "elevated_surface.background": "#0e1c21",
                "toolbar.background": "#0e1c2190",
                "tab_bar.background": "#0e1c2190",
                "tab.inactive_background": "#0e1c2190",
                "tab.active_background": "#879fa830",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0e1c21",
                "scrollbar.thumb.background": "#879fa8",
                "editor.gutter.background": "#0e1c2190",
                "terminal.background": "#0e1c2110",
                "terminal.foreground": "#c2c6c7",
                "terminal.dim_foreground": "#c2c6c7",
                "terminal.bright_foreground": "#c2c6c7",
                "terminal.ansi.black": "#0e1c21",
                "terminal.ansi.red": "#879fa8",
                "terminal.ansi.green": "#7998a9",
                "terminal.ansi.yellow": "#6b91aa",
                "terminal.ansi.blue": "#969fa8",
                "terminal.ansi.magenta": "#a5a3a7",
                "terminal.ansi.cyan": "#b1acb1",
                "terminal.ansi.white": "#c2c6c7",
                "terminal.ansi.bright_black": "#5d6d72",
                "terminal.ansi.bright_red": "#879fa8",
                "terminal.ansi.bright_green": "#7998a9",
                "terminal.ansi.bright_yellow": "#6b91aa",
                "terminal.ansi.bright_blue": "#969fa8",
                "terminal.ansi.bright_magenta": "#a5a3a7",
                "terminal.ansi.bright_cyan": "#b1acb1",
                "terminal.ansi.bright_white": "#c2c6c7",
                "modified": "#879fa8",
                "syntax": {
                    "attribute": {
                        "color": "#879fa8"
                    },
                    "boolean": {
                      "color": "#7998a9"
                    },
                    "comment": {
                      "color": "#5d6d72"
                    },
                    "comment.doc": {
                      "color": "#5d6d72"
                    },
                    "constant": {
                      "color": "#7998a9"
                    },
                    "function": {
                      "color": "#b1acb1"
                    },
                    "keyword": {
                      "color": "#969fa8"
                    },
                    "number": {
                      "color": "#a5a3a7"
                    },
                    "operator": {
                      "color": "#969fa8"
                    },
                    "string": {
                      "color": "#879fa8"
                    },
                    "variable": {
                      "color": "#7998a9"
                    }
                },
                "players": [
                  {
                    "cursor": "#879fa8",
                    "background": "#0e1c21",
                    "selection": "#879fa830"
                  }
                ]
            }
        }
    ]
}
